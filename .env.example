# Supabase (required for Google OAuth + SSR auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# App URL (required in production OAuth flow)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# PayPal Checkout (server uses PAYPAL_CLIENT_ID/SECRET; client uses NEXT_PUBLIC_PAYPAL_CLIENT_ID)
# PAYPAL_ENV=sandbox|live
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
